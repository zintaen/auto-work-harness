# --- AUTO_WORK operational state (never commit) ---
.agent-handoff/
HANDOFF.md

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# --- Test / eval / mutation artifacts ---
# NOTE: .gitignore has no inline comments — a trailing `# ...` becomes part of
# the pattern and silently matches nothing. Keep every comment on its own line.
.pytest_cache/
.ruff_cache/
.hypothesis/
.mypy_cache/
.mutmut-cache
mutants/
.coverage
# coverage parallel-mode shards: .coverage.<host>.<pid>.<rand>
.coverage.*
htmlcov/
# multi-seed eval output (regenerate from goldenset)
eval-runs/
*.evalreport.json

# --- OS ---
.DS_Store
